# ─────────────────────────────────────────────────────
#  PouchCare OS — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/pouchcare
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change_me_minimum_32_characters_long
JWT_REFRESH_SECRET=change_me_different_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=hello@pouchcare.com

# ── File Storage (S3 / Cloudflare R2) ─────────────────
S3_BUCKET=pouchcare-uploads
S3_REGION=eu-central-1
S3_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_ENDPOINT=                        # Leave blank for AWS, set for R2

# ── App URLs ───────────────────────────────────────────
API_URL=https://api.pouchcare.com.bd
LANDING_URL=https://pouchcare.com.bd
MANAGEMENT_URL=https://m.pouchcare.com
OFFICE_URL=https://office.pouchcare.com.bd
PORTAL_URL=https://my.pouchcare.com

# ── Ports (local dev) ─────────────────────────────────
API_PORT=8000
LANDING_PORT=5173
MANAGEMENT_PORT=5174
OFFICE_PORT=5175
PORTAL_PORT=5176

# ── Frontend (Vite prefix: VITE_) ─────────────────────
VITE_API_URL=http://localhost:8000/v1
VITE_APP_ENV=development

# ── Notion (for schema export script only) ─────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub (for task sync script only) ─────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=franklinclintonwriter-ui/PouchCare

# ── Exchange Rate ──────────────────────────────────────
DEFAULT_USD_TO_BDT=124

# ── Referral ───────────────────────────────────────────
COMMISSION_RATE=0.20
COMMISSION_HOLD_DAYS=14
MIN_PAYOUT_USD=50
