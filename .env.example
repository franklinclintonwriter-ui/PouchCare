# ─────────────────────────────────────────────────────
#  PouchCare OS — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/pouchcare
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change_me_minimum_32_characters_long
JWT_REFRESH_SECRET=change_me_different_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=hello@pouchcare.com

# ── File Storage (S3 / Cloudflare R2) ─────────────────
# R2: set S3_ENDPOINT to your https://<id>.r2.cloudflarestorage.com and use R2 "S3 API" keys.
# S3_ACCESS_KEY / S3_SECRET_KEY OR S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY (same as apps/api/.env).
S3_BUCKET=pouchcare-uploads
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
API_URL=http://localhost:7000
# Dev-only: allow ./uploads instead of R2. Must be false in production.
STORAGE_LOCAL_FALLBACK=false

# ── App URLs ───────────────────────────────────────────
API_URL=https://api.pouchcare.com.bd
LANDING_URL=https://pouchcare.com.bd
MANAGEMENT_URL=https://m.pouchcare.com
OFFICE_URL=https://office.pouchcare.com.bd
# Client portal lives on the landing domain (see apps/landing/docs/CLIENT_PORTAL_PAGES_PLAN.md)
PORTAL_URL=https://pouchcare.com

# ── Ports (local dev) ─────────────────────────────────
API_PORT=8000
LANDING_PORT=5173
MANAGEMENT_PORT=5174
OFFICE_PORT=5175
# PORTAL_PORT removed — use LANDING_PORT for the marketing + client SPA

# ── Frontend (Vite prefix: VITE_) ─────────────────────
VITE_API_URL=http://localhost:8000/v1
VITE_APP_ENV=development

# ── Notion (for schema export script only) ─────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudflare (API automation + Tunnel; optional) ───────
# Used by scripts/cloudflare-tunnel-docker-setup.ps1 (npm run tunnel:docker:setup).
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=   # Tunnel Edit + DNS Edit on target zone
# CLOUDFLARE_ZONE_ID=     # or set CLOUDFLARE_ZONE_NAME=pouchcare.com
# CLOUDFLARE_ZONE_NAME=pouchcare.com
# After setup, TUNNEL_TOKEN is written here for docker-compose.hosting.yml profile `tunnel`.
# TUNNEL_TOKEN=

# ── docker-compose.hosting.dev.yml (api-dev.pouchcare.com) ──
# MYSQL_PASSWORD_DEV=strong_password_here
# API_URL_DEV=https://api-dev.pouchcare.com

# ── GitHub (for task sync script only) ─────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=franklinclintonwriter-ui/PouchCare

# ── Exchange Rate ──────────────────────────────────────
DEFAULT_USD_TO_BDT=124

# ── Referral ───────────────────────────────────────────
COMMISSION_RATE=0.20
COMMISSION_HOLD_DAYS=14
MIN_PAYOUT_USD=50
