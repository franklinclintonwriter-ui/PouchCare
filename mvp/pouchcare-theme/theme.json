{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "800px",
      "wideSize": "1140px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "primary", "color": "#1E3A5F", "name": "Primary" },
        { "slug": "brand", "color": "#1E3A5F", "name": "Brand" },
        { "slug": "primary-dark", "color": "#152A45", "name": "Primary Dark" },
        { "slug": "accent-cyan", "color": "#5B8FA8", "name": "Accent Teal" },
        { "slug": "accent-gold", "color": "#B8860B", "name": "Accent Gold" },
        { "slug": "accent-orange", "color": "#C17817", "name": "Accent Bronze" },
        { "slug": "surface", "color": "#FAFAFA", "name": "Surface" },
        { "slug": "text", "color": "#1F2937", "name": "Text" },
        { "slug": "text-muted", "color": "#6B7280", "name": "Text Muted" },
        { "slug": "white", "color": "#FFFFFF", "name": "White" },
        { "slug": "footer-bg", "color": "#111827", "name": "Footer Background" }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "%", "vh", "vw"],
      "spacingScale": {
        "operator": "*",
        "increment": 1.25,
        "steps": 10,
        "mediumStep": 1.5,
        "unit": "rem"
      }
    },
    "typography": {
      "fluid": true,
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "fontFamily": "\"Plus Jakarta Sans\", sans-serif",
          "name": "Heading",
          "slug": "heading"
        },
        {
          "fontFamily": "\"Inter\", sans-serif",
          "name": "Body",
          "slug": "body"
        }
      ],
      "fontSizes": [
        { "slug": "xs", "size": "0.75rem", "name": "Extra Small" },
        { "slug": "sm", "size": "0.875rem", "name": "Small" },
        { "slug": "md", "size": "1rem", "name": "Medium" },
        { "slug": "lg", "size": "1.125rem", "name": "Large" },
        { "slug": "xl", "size": "1.25rem", "name": "Extra Large" },
        { "slug": "2xl", "size": "1.5rem", "name": "2X Large" },
        { "slug": "3xl", "size": "2rem", "name": "3X Large" },
        { "slug": "4xl", "size": "2.5rem", "name": "4X Large" },
        { "slug": "display", "size": "3.75rem", "name": "Display" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--text)"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--primary-dark)"
          }
        }
      },
      "button": {
        "border": {
          "radius": "4px"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "fontWeight": "500",
          "letterSpacing": "0.01em"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--primary-dark)"
          }
        }
      },
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "lineHeight": "1.2",
          "letterSpacing": "-0.02em"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "600",
          "lineHeight": "1.25",
          "letterSpacing": "-0.01em"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "500",
          "lineHeight": "1.4"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "500",
          "lineHeight": "1.4",
          "textTransform": "uppercase",
          "letterSpacing": "0.05em",
          "fontSize": "var(--wp--preset--font-size--sm)"
        }
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "lineHeight": "1.7",
      "fontSize": "var(--wp--preset--font-size--md)"
    },
    "spacing": {
      "blockGap": "1.5rem"
    }
  }
}
