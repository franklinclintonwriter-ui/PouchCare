{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "840px",
      "wideSize": "1200px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "primary", "color": "#0A7AFF", "name": "Primary" },
        { "slug": "brand", "color": "#0A7AFF", "name": "Brand" },
        { "slug": "primary-dark", "color": "#0062D6", "name": "Primary Dark" },
        { "slug": "accent-cyan", "color": "#00C6FF", "name": "Accent Cyan" },
        { "slug": "accent-gold", "color": "#FFB800", "name": "Accent Gold" },
        { "slug": "accent-orange", "color": "#FF8C00", "name": "Accent Orange" },
        { "slug": "surface", "color": "#F5F7FA", "name": "Surface" },
        { "slug": "text", "color": "#1A1A2E", "name": "Text" },
        { "slug": "white", "color": "#FFFFFF", "name": "White" }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "%", "vh", "vw"],
      "spacingScale": {
        "operator": "*",
        "increment": 1.25,
        "steps": 8,
        "mediumStep": 1.25,
        "unit": "rem"
      }
    },
    "typography": {
      "fluid": true,
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "fontFamily": "\"Plus Jakarta Sans\", sans-serif",
          "name": "Heading",
          "slug": "heading"
        },
        {
          "fontFamily": "\"Inter\", sans-serif",
          "name": "Body",
          "slug": "body"
        }
      ],
      "fontSizes": [
        { "slug": "sm", "size": "0.875rem", "name": "Small" },
        { "slug": "md", "size": "1rem", "name": "Medium" },
        { "slug": "lg", "size": "1.25rem", "name": "Large" },
        { "slug": "xl", "size": "2rem", "name": "Extra Large" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--text)"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "button": {
        "border": {
          "radius": "var(--pc-radius-button)"
        }
      }
    },
    "typography": {
      "lineHeight": "1.6"
    }
  }
}
