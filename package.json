{
  "name": "pouchcare-os",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev":          "turbo run dev",
    "build":        "turbo run build",
    "lint":         "turbo run lint",
    "test":         "turbo run test",
    "type-check":   "turbo run type-check",
    "dev:api":      "turbo run dev --filter=api",
    "dev:landing":  "turbo run dev --filter=landing",
    "dev:mgmt":     "turbo run dev --filter=m.pouchcare.com",
    "dev:office":   "turbo run dev --filter=office",
    "dev:portal":   "turbo run dev --filter=client-portal",
    "export:notion": "node scripts/export-notion.mjs",
    "sync:github":  "node scripts/sync-tasks-to-github.mjs",
    "db:up":        "docker compose up -d",
    "db:down":      "docker compose down",
    "db:setup":     "npm run db:push -w api && npm run db:seed -w api",
    "db:setup:win": "powershell -ExecutionPolicy Bypass -File scripts/dev-db-setup.ps1",
    "dev:full": "powershell -ExecutionPolicy Bypass -File scripts/dev-full.ps1",
    "db:push":      "npm run db:push -w api",
    "db:seed":      "npm run db:seed -w api",
    "test:e2e":     "playwright test",
    "test:e2e:ui":  "playwright test --ui"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@playwright/test": "^1.49.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.9.0"
}
