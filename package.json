{
  "name": "pouchcare-os",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "dev:api": "turbo run dev --filter=api",
    "dev:landing": "turbo run dev --filter=landing",
    "dev:mgmt": "turbo run dev --filter=m.pouchcare.com",
    "start": "powershell -ExecutionPolicy Bypass -File scripts/dev-start.ps1",
    "dev:full": "powershell -ExecutionPolicy Bypass -File scripts/dev-full.ps1",
    "dev:stack": "turbo run dev --filter=api --filter=m.pouchcare.com",
    "dev:win": "powershell -ExecutionPolicy Bypass -File scripts/dev-start.ps1",
    "export:notion": "node scripts/export-notion.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:setup": "npm run db:push -w api && npm run db:seed -w api",
    "db:setup:win": "powershell -ExecutionPolicy Bypass -File scripts/dev-db-setup.ps1",
    "db:ensure": "powershell -ExecutionPolicy Bypass -File scripts/ensure-postgres-and-seed.ps1",
    "db:push": "npm run db:push -w api",
    "db:seed": "npm run db:seed -w api",
    "db:reset-demo": "npm run db:reset-demo -w api",
    "bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap-local.ps1",
    "prisma": "cd apps/api && npx prisma",
    "prisma:studio": "cd apps/api && npx prisma studio",
    "prisma:generate": "cd apps/api && npx prisma generate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
