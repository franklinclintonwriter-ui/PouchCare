{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "PouchCare Design Tokens",
  "version": "2.0.0",
  "colors": {
    "primary": {
      "DEFAULT": "#1E3A5F",
      "dark": "#152A45",
      "deeper": "#0F1F33",
      "light": "#F0F4F8"
    },
    "accent": {
      "cyan": "#5B8FA8",
      "gold": "#B8860B",
      "orange": "#C17817"
    },
    "surface": {
      "light": "#FAFAFA",
      "blue": "#F0F4F8",
      "white": "#FFFFFF"
    },
    "text": {
      "heading": "#1F2937",
      "body": "#4B5563",
      "muted": "#6B7280"
    },
    "footer": {
      "bg": "#111827",
      "text": "#D1D5DB"
    },
    "status": {
      "success": "#059669",
      "warning": "#D97706",
      "error": "#DC2626",
      "info": "#2563EB"
    }
  },
  "typography": {
    "fontFamilies": {
      "heading": "Plus Jakarta Sans, sans-serif",
      "body": "Inter, sans-serif"
    },
    "fontSizes": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "md": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "2rem",
      "4xl": "2.5rem",
      "display": "3.75rem"
    },
    "lineHeight": {
      "tight": "1.2",
      "normal": "1.5",
      "relaxed": "1.7"
    },
    "letterSpacing": {
      "tight": "-0.02em",
      "normal": "0",
      "wide": "0.05em"
    }
  },
  "spacing": {
    "unit": "rem",
    "scale": 1.25,
    "steps": 8
  },
  "borderRadius": {
    "card": "6px",
    "button": "4px",
    "logo": "8px"
  },
  "shadows": {
    "card": "0 1px 3px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.06)",
    "cardHover": "0 4px 12px rgba(0, 0, 0, 0.08)",
    "nav": "0 1px 2px rgba(0, 0, 0, 0.04)"
  }
}
