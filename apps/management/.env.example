# Prefer leaving VITE_API_URL unset: the dev server proxies HTTP `/v1` to apps/api (see apps/management/vite.config.ts).
# WebSocket (`/v1/realtime`) is NOT reliably served via the Vite port — the app defaults to ws://127.0.0.1:7000 in dev
# (same default as the API). If your API uses another port, set one of:
# VITE_API_URL=http://127.0.0.1:7000
# VITE_WS_URL=ws://127.0.0.1:7000/v1/realtime
#
# Production / remote API (e.g. SPA on m.pouchcare.com calling api.pouchcare.com):
# VITE_API_URL=https://api.pouchcare.com
# VITE_WS_URL=wss://api.pouchcare.com/v1/realtime
#
# Cloudflare Pages: production values live in `.env.production` (see `npm run pages:deploy` in repo root).
