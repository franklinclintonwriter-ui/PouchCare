# Prefer leaving these unset: the dev server proxies `/v1` to apps/api using PORT from apps/api/.env.
# Only set VITE_* if the SPA is not behind that proxy — values must match the API port (see apps/api/.env PORT).
# VITE_API_URL=http://127.0.0.1:7000
# VITE_WS_URL=ws://127.0.0.1:7000/v1/realtime
