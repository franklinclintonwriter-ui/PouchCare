# Cloudflare Pages cache headers
# HTML — never cache (always fetch fresh so stale chunk references never happen)
/
  Cache-Control: no-store, must-revalidate

/*.html
  Cache-Control: no-store, must-revalidate

# Hashed JS/CSS/images — immutable long-term cache (Vite fingerprints every filename)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker (if any) — always fresh
/sw.js
  Cache-Control: no-store, must-revalidate

# _redirects and other plain files — short cache
/_redirects
  Cache-Control: no-store
