# API backend URL (used to fetch live services + backlink packages)
VITE_API_URL=http://localhost:7000

# Client area — same host as marketing site (pouchcare.com): leave VITE_PORTAL_URL empty for relative URLs.
# Use a full URL only when the portal SPA is served from another origin (e.g. local dev).
# VITE_PORTAL_URL=https://pouchcare.com
# VITE_PORTAL_URL=http://localhost:5176
#
# Defaults: /my-accounts/login, /my-accounts/register, /dashboard
# VITE_PORTAL_LOGIN_PATH=/my-accounts/login
# VITE_PORTAL_REGISTER_PATH=/my-accounts/register
# VITE_PORTAL_DASHBOARD_PATH=/dashboard
