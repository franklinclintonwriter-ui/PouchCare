// PouchCare OS — Prisma Schema
// Database: PostgreSQL
// Generated: March 2026

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ─────────────────────────────────────────────────────────────────────

enum SystemRole {
  CEO
  CO_MD          @map("Brother / Co-MD")
  OP_MANAGER     @map("Operation Manager")
  HR_MANAGER     @map("HR Manager")
  BRANCH_MANAGER @map("Branch Manager")
  STAFF
  INTERN
}

enum TaskStatus {
  NOT_STARTED @map("Not Started")
  IN_PROGRESS @map("In Progress")
  BLOCKED
  REVIEW
  DONE
}

enum ApprovalStatus {
  WAITING      @map("Waiting for Submission")
  SUBMITTED    @map("Submitted by Staff")
  APPROVED_MGR @map("Approved by Manager")
  REJECTED_MGR @map("Rejected by Manager")
  ESCALATED    @map("Escalated to CEO")
  VERIFIED     @map("Completed & Verified")
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY @map("Half Day")
  REMOTE
}

enum WorkType {
  OFFICE
  REMOTE
  FIELD
  LEAVE
  HOLIDAY
}

enum LeaveType {
  ANNUAL    @map("Annual Leave")
  SICK      @map("Sick Leave")
  EMERGENCY @map("Emergency Leave")
  MATERNITY @map("Maternity Leave")
  PATERNITY @map("Paternity Leave")
  UNPAID    @map("Unpaid Leave")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS @map("In Progress")
  REVIEW
  DELIVERED
  ON_HOLD     @map("On Hold")
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
  REFUNDED
}

enum LeadStage {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum PortalMemberStatus {
  ACTIVE
  PENDING_VERIFICATION @map("Pending Verification")
  SUSPENDED
  INACTIVE
}

enum OrderStatus {
  PENDING
  PROCESSING
  DELIVERED
  REVISION_REQUESTED @map("Revision Requested")
  COMPLETED
  CANCELLED
  REFUNDED
}

enum WalletTxType {
  DEPOSIT
  ORDER_PAYMENT     @map("Order Payment")
  COMMISSION_CREDIT @map("Commission Credit")
  REFUND
  PAYOUT
  ADJUSTMENT
}

enum CommissionStatus {
  PENDING_HOLD @map("Pending Hold")
  AVAILABLE
  PAID_OUT     @map("Paid Out")
  CANCELLED
  FRAUD_HOLD   @map("Fraud Hold")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

enum PaymentMethod {
  PAYONEER
  USDT_TRC20    @map("USDT TRC20")
  BINANCE
  BANK_TRANSFER @map("Bank Transfer")
  CASH
}

// ── MODELS ────────────────────────────────────────────────────────────────────

model StaffMember {
  id                   String     @id @default(uuid())
  memberId             Int        @unique @default(autoincrement()) @map("member_id")
  name                 String
  email                String     @unique
  passwordHash         String     @map("password_hash")
  systemRole           SystemRole @map("system_role")
  status               String     @default("Active")
  branch               String?
  branchId             String?    @map("branch_id")
  jobRole              String?    @map("job_role")
  primarySkill         String?    @map("primary_skill")
  skillLevel           String?    @map("skill_level")
  secondarySkills      String?    @map("secondary_skills")
  toolsKnown           String?    @map("tools_known")
  yearsExperience      Float?     @map("years_experience")
  employmentType       String?    @map("employment_type")
  salary               Float?
  email2               String?    @map("email_alt")
  phone                String?
  whatsapp             String?
  address              String?
  country              String?
  nidPassport          String?    @map("nid_passport")
  emergencyContact     String?    @map("emergency_contact")
  joinDate             DateTime?  @map("join_date")
  terminationDate      DateTime?  @map("termination_date")
  exitReason           String?    @map("exit_reason")
  exitInterviewDone    Boolean    @default(false) @map("exit_interview_done")
  portfolioUrl         String?    @map("portfolio_url")
  linkedinUrl          String?    @map("linkedin_url")
  githubUrl            String?    @map("github_url")
  certifications       String?
  tasksAssigned        Int        @default(0) @map("tasks_assigned")
  tasksCompleted       Int        @default(0) @map("tasks_completed")
  totalTasksRated      Int        @default(0) @map("total_tasks_rated")
  averageTaskRating    Float?     @map("average_task_rating")
  ceoPerformanceRating Float?     @map("ceo_performance_rating")
  ceoRatingNote        String?    @map("ceo_rating_note")
  ceoLastRatedDate     DateTime?  @map("ceo_last_rated_date")
  performanceScore     Float?     @map("performance_score")
  totpSecret           String?    @map("totp_secret")
  twoFactorEnabled     Boolean    @default(false) @map("two_factor_enabled")
  refreshToken         String?    @map("refresh_token")
  lastLoginAt          DateTime?  @map("last_login_at")
  lastLoginIp          String?    @map("last_login_ip")
  preferredCurrency    String     @default("BDT") @map("preferred_currency") // USD | BDT
  avatarUrl            String?    @map("avatar_url") // profile photo URL (R2 or local)
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  // Relations
  tasks              Task[]              @relation("AssignedMember")
  managedTasks       Task[]              @relation("AssignedManager")
  attendance         Attendance[]
  leaveRequests      LeaveRequest[]
  dailyReports       DailyReport[]
  payroll            Payroll[]
  performanceRatings PerformanceRating[]
  devices            Device[]
  toolRuns           ToolRun[]
  documents          StaffDocument[]
  aiConversations    AiConversation[]
  emailAccounts      EmailAccount[]
  exchangeRatesCreated ExchangeRate[] @relation("ExchangeRateCreatedBy")
  exchangeRatesUpdated ExchangeRate[] @relation("ExchangeRateUpdatedBy")
  branchRef            Branch?             @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("staff_members")
}

model StaffDocument {
  id            String    @id @default(uuid())
  staffMemberId String    @map("staff_member_id")
  category      String // identity | education | employment | medical | other
  documentType  String    @map("document_type") // passport | nid | driving_license | degree | certificate | cv | contract | etc
  title         String
  description   String?
  fileName      String    @map("file_name")
  fileSize      Int       @map("file_size")
  mimeType      String    @map("mime_type")
  fileUrl       String    @map("file_url")
  thumbnailUrl  String?   @map("thumbnail_url")
  issueDate     DateTime? @map("issue_date")
  expiryDate    DateTime? @map("expiry_date")
  isVerified    Boolean   @default(false) @map("is_verified")
  verifiedBy    String?   @map("verified_by")
  verifiedAt    DateTime? @map("verified_at")
  uploadedBy    String    @map("uploaded_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  staffMember StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@index([staffMemberId])
  @@index([category])
  @@map("staff_documents")
}

/// Per-role overrides for management UI / API feature flags. Defaults are code-defined; rows here replace defaults.
model RolePermission {
  id        String     @id @default(uuid())
  role      SystemRole
  key       String
  allowed   Boolean
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@unique([role, key])
  @@map("role_permissions")
}

model Task {
  id                  String         @id @default(uuid())
  taskId              Int            @unique @default(autoincrement()) @map("task_id")
  title               String
  status              TaskStatus     @default(NOT_STARTED)
  approvalStatus      ApprovalStatus @default(WAITING) @map("approval_status")
  priority            Priority       @default(MEDIUM)
  category            String?
  createdByRole       String?        @map("created_by_role")
  assignedMemberId    String?        @map("assigned_member_id")
  assignedManagerId   String?        @map("assigned_manager_id")
  assignedBranch      String?        @map("assigned_branch")
  branchId            String?        @map("branch_id")
  assignedBy          String?        @map("assigned_by")
  multipleAssignees   String?        @map("multiple_assignees")
  relatedProject      String?        @map("related_project")
  relatedProjectId    String?        @map("related_project_id")
  relatedClient       String?        @map("related_client")
  taskUrl             String?        @map("task_url")
  startDate           DateTime?      @map("start_date")
  deadline            DateTime?
  completedDate       DateTime?      @map("completed_date")
  estimatedHours      Float?         @map("estimated_hours")
  actualHours         Float?         @map("actual_hours")
  progress            Int            @default(0)
  isRecurring         Boolean        @default(false) @map("is_recurring")
  recurringFrequency  String?        @map("recurring_frequency")
  staffSubmissionNote String?        @map("staff_submission_note")
  managerApprovedBy   String?        @map("manager_approved_by")
  managerApprovedDate DateTime?      @map("manager_approved_date")
  managerApprovalNote String?        @map("manager_approval_note")
  ceoVerified         Boolean        @default(false) @map("ceo_verified")
  ceoVerifiedDate     DateTime?      @map("ceo_verified_date")
  ceoWorkRating       Float?         @map("ceo_work_rating")
  ceoRatedDate        DateTime?      @map("ceo_rated_date")
  ceoRatingNote       String?        @map("ceo_rating_note")
  attachment1         String?        @map("attachment_1")
  attachment2         String?        @map("attachment_2")
  attachment3         String?        @map("attachment_3")
  attachmentNotes     String?        @map("attachment_notes")
  // task_attachments: JSON array of { url, name, uploadedAt }
  taskAttachments     Json?          @map("task_attachments")
  progressUpdatedAt   DateTime?      @map("progress_updated_at")
  notes               String?
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  // Relations
  assignedMember    StaffMember?  @relation("AssignedMember", fields: [assignedMemberId], references: [id])
  assignedManager   StaffMember?  @relation("AssignedManager", fields: [assignedManagerId], references: [id])
  relatedProjectRef Project?      @relation("TaskRelatedProject", fields: [relatedProjectId], references: [id])
  comments          TaskComment[]
  branchRef         Branch?       @relation(fields: [branchId], references: [id])

  @@index([relatedProjectId])
  @@index([branchId])
  @@map("tasks")
}

model TaskComment {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  authorId   String   @map("author_id")
  authorName String   @map("author_name")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model Project {
  id                String         @id @default(uuid())
  projectId         Int            @unique @default(autoincrement()) @map("project_id")
  name              String
  status            ProjectStatus  @default(PENDING)
  approvalStatus    ApprovalStatus @default(WAITING) @map("approval_status")
  priority          Priority       @default(MEDIUM)
  projectType       String?        @map("project_type")
  serviceType       String?        @map("service_type")
  paymentStatus     PaymentStatus  @default(UNPAID) @map("payment_status")
  currency          String         @default("USD")
  clientName        String?        @map("client_name")
  clientEmail       String?        @map("client_email")
  projectManager    String?        @map("project_manager")
  assignedManager   String?        @map("assigned_manager")
  assignedTo        String?        @map("assigned_to")
  assignedBranch    String?        @map("assigned_branch")
  branchId          String?        @map("branch_id")
  multipleAssignees String?        @map("multiple_assignees")
  startDate         DateTime?      @map("start_date")
  deadline          DateTime?
  price             Float?
  priceBdt          Float?         @map("price_bdt")
  paidAmount        Float?         @map("paid_amount")
  estimatedHours    Float?         @map("estimated_hours")
  actualHours       Float?         @map("actual_hours")
  progress          Int            @default(0)
  repeatClient      Boolean        @default(false) @map("repeat_client")
  invoiceNumber     String?        @map("invoice_number")
  contractUrl       String?        @map("contract_url")
  deliveryLink      String?        @map("delivery_link")
  feedback          String?
  ceoVerified       Boolean        @default(false) @map("ceo_verified")
  ceoWorkRating     Float?         @map("ceo_work_rating")
  notes             String?
  createdByRole     String?        @map("created_by_role")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  tasks     Task[]  @relation("TaskRelatedProject")
  branchRef Branch? @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("projects")
}

model Attendance {
  id              String           @id @default(uuid())
  attendanceId    Int              @unique @default(autoincrement()) @map("attendance_id")
  staffMemberId   String           @map("staff_member_id")
  name            String
  branch          String?
  branchId        String?          @map("branch_id")
  date            DateTime         @db.Date
  status          AttendanceStatus
  workType        WorkType         @default(OFFICE) @map("work_type")
  staffSystemRole String?          @map("staff_system_role")
  leaveType       String?          @map("leave_type")
  checkInTime     DateTime?        @map("check_in_time")
  checkOutTime    DateTime?        @map("check_out_time")
  hoursWorked     Float?           @map("hours_worked")
  overtimeHours   Float?           @default(0) @map("overtime_hours")
  approvedBy      String?          @map("approved_by")
  loginIp         String?          @map("login_ip")
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  staffMember     StaffMember      @relation(fields: [staffMemberId], references: [id])
  branchRef       Branch?          @relation(fields: [branchId], references: [id])

  @@unique([staffMemberId, date])
  @@index([branchId])
  @@map("attendance")
}

model LeaveRequest {
  id                 String      @id @default(uuid())
  leaveId            Int         @unique @default(autoincrement()) @map("leave_id")
  staffMemberId      String      @map("staff_member_id")
  staffName          String      @map("staff_name")
  staffSystemRole    String?     @map("staff_system_role")
  branch             String?
  branchId           String?     @map("branch_id")
  leaveType          LeaveType   @map("leave_type")
  status             LeaveStatus @default(PENDING)
  startDate          DateTime    @map("start_date")
  endDate            DateTime    @map("end_date")
  totalDays          Int         @map("total_days")
  annualLeaveBalance Int?        @map("annual_leave_balance")
  sickLeaveBalance   Int?        @map("sick_leave_balance")
  totalDaysUsedYear  Int?        @map("total_days_used_year")
  reason             String?
  approvedBy         String?     @map("approved_by")
  notes              String?
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  staffMember        StaffMember @relation(fields: [staffMemberId], references: [id])
  branchRef          Branch?     @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("leave_requests")
}

model DailyReport {
  id                String      @id @default(uuid())
  reportId          Int         @unique @default(autoincrement()) @map("report_id")
  staffMemberId     String      @map("staff_member_id")
  submitterName     String      @map("submitter_name")
  submitterRole     String?     @map("submitter_role")
  branch            String?
  branchId          String?     @map("branch_id")
  reportDate        DateTime    @map("report_date") @db.Date
  tasksCompleted    String      @map("tasks_completed")
  plannedTomorrow   String      @map("planned_tomorrow")
  blockers          String?
  hoursWorked       Float       @map("hours_worked")
  overtimeHours     Float?      @default(0) @map("overtime_hours")
  mood              String?
  relatedClient     String?     @map("related_client")
  loginIp           String?     @map("login_ip")
  managerReviewNote String?     @map("manager_review_note")
  status            String      @default("Submitted")
  notes             String?
  createdAt         DateTime    @default(now()) @map("created_at")
  staffMember       StaffMember @relation(fields: [staffMemberId], references: [id])
  branchRef         Branch?     @relation(fields: [branchId], references: [id])

  @@unique([staffMemberId, reportDate])
  @@index([branchId])
  @@map("daily_reports")
}

model PerformanceRating {
  id            String      @id @default(uuid())
  staffMemberId String      @map("staff_member_id")
  staffName     String      @map("staff_name")
  systemRole    String?     @map("system_role")
  branch        String?
  branchId      String?     @map("branch_id")
  ratedBy       String      @map("rated_by")
  reviewPeriod  String?     @map("review_period")
  reviewQuarter String?     @map("review_quarter")
  reviewYear    Int?        @map("review_year")
  overallRating Float       @map("overall_rating")
  taskQuality   Float?      @map("task_quality")
  communication Float?
  punctuality   Float?
  teamwork      Float?
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id])
  branchRef     Branch?     @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("performance_ratings")
}

model Payroll {
  id            String      @id @default(uuid())
  staffMemberId String      @map("staff_member_id")
  staffName     String      @map("staff_name")
  systemRole    String?     @map("system_role")
  branch        String?
  branchId      String?     @map("branch_id")
  month         String
  year          Int
  baseSalary    Float       @map("base_salary")
  bonus         Float?      @default(0)
  deductions    Float?      @default(0)
  netSalary     Float       @map("net_salary")
  paymentMethod String?     @map("payment_method")
  paymentStatus String      @default("Pending") @map("payment_status")
  paymentDate   DateTime?   @map("payment_date")
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id])
  branchRef     Branch?     @relation(fields: [branchId], references: [id])

  @@unique([staffMemberId, month, year])
  @@index([branchId])
  @@map("payroll")
}

model Branch {
  id                 String              @id @default(uuid())
  name               String              @unique
  country            String?
  city               String?
  type               String?
  status             String              @default("Active")
  branchManager      String?             @map("branch_manager")
  staffCount         Int?                @default(0) @map("staff_count")
  email              String?
  phone              String?
  address            String?
  establishedDate    DateTime?           @map("established_date")
  notes              String?
  createdAt          DateTime            @default(now()) @map("created_at")
  cameraDevices      CameraDevice[]
  vigiNvrIntegration VigiNvrIntegration?
  exchangeRates      ExchangeRate[]
  staffMembers       StaffMember[]
  tasks              Task[]
  projects           Project[]
  attendance         Attendance[]
  leaveRequests      LeaveRequest[]
  dailyReports       DailyReport[]
  performanceRatings PerformanceRating[]
  payroll            Payroll[]

  @@map("branches")
}

model Device {
  id             String      @id @default(uuid())
  staffMemberId  String      @map("staff_member_id")
  deviceName     String      @map("device_name")
  deviceType     String?     @map("device_type")
  ipAddress      String?     @map("ip_address")
  macAddress     String?     @map("mac_address")
  os             String?
  status         String      @default("Active")
  systemRole     String?     @map("system_role")
  branch         String?
  registeredDate DateTime?   @map("registered_date")
  lastActive     DateTime?   @map("last_active")
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  staffMember    StaffMember @relation(fields: [staffMemberId], references: [id])

  @@map("devices")
}

model Invoice {
  id               String        @id @default(uuid())
  invoiceNumber    String        @unique @map("invoice_number")
  clientName       String?       @map("client_name")
  clientEmail      String?       @map("client_email")
  service          String?
  status           String        @default("Draft")
  paymentMethod    String?       @map("payment_method")
  amountUsd        Float         @map("amount_usd")
  amountBdt        Float?        @map("amount_bdt")
  issueDate        DateTime      @map("issue_date")
  dueDate          DateTime?     @map("due_date")
  paidDate         DateTime?     @map("paid_date")
  projectReference String?       @map("project_reference")
  invoiceUrl       String?       @map("invoice_url")
  notes            String?
  portalMemberId   String?       @map("portal_member_id")
  portalMember     PortalMember? @relation(fields: [portalMemberId], references: [id])
  createdAt        DateTime      @default(now()) @map("created_at")

  @@map("invoices")
}

model Expense {
  id            String   @id @default(uuid())
  title         String
  category      String?
  amountUsd     Float    @map("amount_usd")
  amountBdt     Float?   @map("amount_bdt")
  paidBy        String?  @map("paid_by")
  branch        String?
  paymentMethod String?  @map("payment_method")
  status        String   @default("Pending")
  expenseDate   DateTime @map("expense_date")
  approvedBy    String?  @map("approved_by")
  receiptUrl    String?  @map("receipt_url")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("expenses")
}

model MonthlyRevenue {
  id               String   @id @default(uuid())
  month            String
  year             Int
  totalRevenueUsd  Float    @map("total_revenue_usd")
  totalRevenueBdt  Float?   @map("total_revenue_bdt")
  totalExpensesUsd Float?   @map("total_expenses_usd")
  netProfitUsd     Float?   @map("net_profit_usd")
  clientCount      Int?     @map("client_count")
  newClients       Int?     @map("new_clients")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([month, year])
  @@map("monthly_revenue")
}

model ExchangeRate {
  id            String   @id @default(uuid())
  usdToBdt      Float    @map("usd_to_bdt")
  usdToAed      Float?   @map("usd_to_aed")
  bdtToAed      Float?   @map("bdt_to_aed")
  effectiveDate DateTime @map("effective_date")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  branchId      String?  @map("branch_id")
  createdById   String?  @map("created_by_id")
  updatedById   String?  @map("updated_by_id")

  branch    Branch?      @relation(fields: [branchId], references: [id])
  createdBy StaffMember? @relation("ExchangeRateCreatedBy", fields: [createdById], references: [id])
  updatedBy StaffMember? @relation("ExchangeRateUpdatedBy", fields: [updatedById], references: [id])

  @@map("exchange_rates")
}

model CrmLead {
  id                String    @id @default(uuid())
  leadId            Int       @unique @default(autoincrement()) @map("lead_id")
  company           String
  contactName       String?   @map("contact_name")
  email             String?
  phone             String?
  whatsapp          String?
  country           String?
  linkedinUrl       String?   @map("linkedin_url")
  stage             LeadStage @default(NEW)
  source            String?
  serviceInterested String?   @map("service_interested")
  lostReason        String?   @map("lost_reason")
  budgetUsd         Float?    @map("budget_usd")
  estimatedValue    Float?    @map("estimated_value")
  leadScore         Int?      @map("lead_score")
  followUpCount     Int       @default(0) @map("follow_up_count")
  owner             String?
  assignedTo        String?   @map("assigned_to")
  lastContactDate   DateTime? @map("last_contact_date")
  nextFollowUpDate  DateTime? @map("next_follow_up_date")
  convertedToClient Boolean   @default(false) @map("converted_to_client")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("crm_leads")
}

model SalesOrder {
  id               String        @id @default(uuid())
  orderId          Int           @unique @default(autoincrement()) @map("order_id")
  clientName       String        @map("client_name")
  service          String?
  status           String        @default("New")
  paymentStatus    PaymentStatus @default(UNPAID) @map("payment_status")
  amountUsd        Float         @map("amount_usd")
  assignedTo       String?       @map("assigned_to")
  branch           String?
  orderDate        DateTime      @map("order_date")
  deadline         DateTime?
  deliveryDate     DateTime?     @map("delivery_date")
  deliveryLink     String?       @map("delivery_link")
  invoiceReference String?       @map("invoice_reference")
  revisionCount    Int           @default(0) @map("revision_count")
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")

  @@map("sales_orders")
}

model ClientAccount {
  id              String    @id @default(uuid())
  clientName      String    @map("client_name")
  email           String    @unique
  phone           String?
  whatsapp        String?
  country         String?
  status          String    @default("Active")
  totalSpentUsd   Float     @default(0) @map("total_spent_usd")
  totalOrders     Int       @default(0) @map("total_orders")
  firstOrderDate  DateTime? @map("first_order_date")
  lastOrderDate   DateTime? @map("last_order_date")
  assignedManager String?   @map("assigned_manager")
  source          String?
  linkedinUrl     String?   @map("linkedin_url")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("client_accounts")
}

model Service {
  id               String        @id @default(uuid())
  name             String        @unique
  category         String?
  status           String        @default("Active")
  basePriceUsd     Float?        @map("base_price_usd")
  priceBdt         Float?        @map("price_bdt")
  turnaroundDays   Int?          @map("turnaround_days")
  shortDescription String?       @map("short_description")
  fullDescription  String?       @map("full_description")
  slug             String        @unique
  icon             String?
  featured         Boolean       @default(false)
  displayOrder     Int?          @map("display_order")
  metaTitle        String?       @map("meta_title")
  metaDescription  String?       @map("meta_description")
  createdAt        DateTime      @default(now()) @map("created_at")
  plans            ServicePlan[]

  @@map("services")
}

/// Tiered plans for a Service. Each Service can have 0..N plans (Starter / Pro / Enterprise).
/// Generalizes the BacklinkPackage idea so any service can offer pricing tiers.
model ServicePlan {
  id           String   @id @default(uuid())
  serviceId    String   @map("service_id")
  service      Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name         String
  priceUsd     Float    @map("price_usd")
  priceBdt     Float?   @map("price_bdt")
  deliveryDays Int?     @map("delivery_days")
  features     Json     @default("[]") // string[] stored as JSON (MySQL has no scalar list type)
  isPopular    Boolean  @default(false) @map("is_popular")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([serviceId, displayOrder])
  @@map("service_plans")
}

/// Saved filter presets for the Admin Panel Clients list. Each segment is a
/// named filter set (status, country, manager, etc.) that any staff member
/// can apply with one click. Shared across the team by default.
model ClientSegment {
  id          String   @id @default(uuid())
  name        String   @unique
  params      Json // { status?: string; country?: string; manager?: string; q?: string }
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("client_segments")
}

model BacklinkPackage {
  id             String   @id @default(uuid())
  name           String   @unique
  type           String?
  daRange        String?  @map("da_range")
  status         String   @default("Active")
  pricePerLink   Float    @map("price_per_link")
  priceX10       Float?   @map("price_x10")
  priceX50       Float?   @map("price_x50")
  priceX100      Float?   @map("price_x100")
  priceX1000     Float?   @map("price_x1000")
  turnaroundDays Int?     @map("turnaround_days")
  featured       Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("backlink_packages")
}

/// Domain name inventory. Rows may be (a) PouchCare internal ops (staff `/assets/domains`) and/or
/// (b) customer-owned (`portalMemberId` set) for portal `/portal/hosting/domains`. Same table, different routes/UX.
model Domain {
  id                     String        @id @default(uuid())
  domainId               Int           @unique @default(autoincrement()) @map("domain_id")
  domainName             String        @unique @map("domain_name")
  status                 String        @default("Active")
  lifecycleStatus        String        @default("INCOMPLETE") @map("lifecycle_status")
  registrar              String?
  assignedTo             String?       @map("assigned_to")
  assignedStaffId        String?       @map("assigned_staff_id")
  expiryDate             DateTime?     @map("expiry_date")
  registrationDate       DateTime?     @map("registration_date")
  annualRenewalCost      Float?        @map("annual_renewal_cost")
  domainAgeYears         Float?        @map("domain_age_years")
  daScore                Int?          @map("da_score")
  drScore                Int?          @map("dr_score")
  backlinksCount         Int?          @map("backlinks_count")
  indexedPages           Int?          @map("indexed_pages")
  monthlyTraffic         Int?          @map("monthly_traffic")
  niche                  String?
  hostingServer          String?       @map("hosting_server")
  sslStatus              String?       @map("ssl_status")
  nameservers            String?
  dnsRecords             String?       @map("dns_records")
  whoisPrivacy           Boolean       @default(false) @map("whois_privacy")
  adsenseConnected       Boolean       @default(false) @map("adsense_connected")
  adsensePublisherId     String?       @map("adsense_publisher_id")
  analyticsId            String?       @map("analytics_id")
  searchConsoleVerified  Boolean       @default(false) @map("search_console_verified")
  notes                  String?
  portalMemberId         String?       @map("portal_member_id")
  portalMember           PortalMember? @relation(fields: [portalMemberId], references: [id])
  createdAt              DateTime      @default(now()) @map("created_at")

  @@map("domains")
}

/// PouchCare internal server/hosting assets — staff `/assets/servers` only (no client portal mirror).
model Server {
  id             String    @id @default(uuid())
  name           String    @unique
  provider       String?
  type           String?
  status         String    @default("Active")
  ipAddress      String?   @map("ip_address")
  location       String?
  os             String?
  ramGb          Int?      @map("ram_gb")
  storageGb      Int?      @map("storage_gb")
  monthlyCostUsd Float?    @map("monthly_cost_usd")
  renewalDate    DateTime? @map("renewal_date")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("servers")
}

/// Website records. Staff use `/assets/websites` (internal inventory); portal members use
/// `/portal/websites` (scoped by `portalMemberId`). Do not confuse the two products.
model Website {
  id              String        @id @default(uuid())
  name            String        @unique
  url             String?
  type            String?
  status          String        @default("Live")
  platform        String?
  cms             String?
  programmingLang String?       @map("programming_lang")
  framework       String?
  hostedOn        String?       @map("hosted_on")
  domainLinked    String?       @map("domain_linked")
  domainId        String?       @map("domain_id")
  serverId        String?       @map("server_id")
  assignedManager String?       @map("assigned_manager")
  assignedStaffId String?       @map("assigned_staff_id")
  monthlyTraffic  Int?          @map("monthly_traffic")
  daScore         Int?          @map("da_score")
  sslStatus       String?       @map("ssl_status")
  adsenseConnected Boolean      @default(false) @map("adsense_connected")
  adsenseEarnings Float?        @map("adsense_earnings")
  analyticsId     String?       @map("analytics_id")
  uptimePercent   Float?        @map("uptime_percent")
  avgLoadTime     Float?        @map("avg_load_time")
  lastUpdated     DateTime?     @map("last_updated")
  renewalDate     DateTime?     @map("renewal_date")
  notes           String?
  portalMemberId  String?       @map("portal_member_id")
  portalMember    PortalMember? @relation(fields: [portalMemberId], references: [id])
  createdAt       DateTime      @default(now()) @map("created_at")

  @@map("websites")
}

model JobPosition {
  id              String           @id @default(uuid())
  title           String
  department      String?
  branch          String?
  status          String           @default("Open")
  employmentType  String?          @map("employment_type")
  salaryMin       Float?           @map("salary_min")
  salaryMax       Float?           @map("salary_max")
  openings        Int              @default(1)
  applications    Int              @default(0)
  published       Boolean          @default(true)
  postedDate      DateTime?        @map("posted_date")
  deadline        DateTime?
  jobDescription  String?          @map("job_description")
  createdAt       DateTime         @default(now()) @map("created_at")
  jobApplications JobApplication[]

  @@map("job_positions")
}

model JobApplication {
  id               String      @id @default(uuid())
  positionId       String      @map("position_id")
  applicantName    String      @map("applicant_name")
  email            String
  phone            String?
  status           String      @default("New")
  source           String?
  appliedDate      DateTime    @default(now()) @map("applied_date")
  hiredDate        DateTime?   @map("hired_date")
  interviewDate    DateTime?   @map("interview_date")
  cvUrl            String?     @map("cv_url")
  portfolioUrl     String?     @map("portfolio_url")
  experienceYears  Float?      @map("experience_years")
  expectedSalary   Float?      @map("expected_salary")
  interviewerNotes String?     @map("interviewer_notes")
  rejectionReason  String?     @map("rejection_reason")
  offerSalary      Float?      @map("offer_salary")
  score            Float?
  notes            String?
  createdAt        DateTime    @default(now()) @map("created_at")
  position         JobPosition @relation(fields: [positionId], references: [id])

  @@map("job_applications")
}

// ── PORTAL MODELS ─────────────────────────────────────────────────────────────

model PortalMember {
  id                    String             @id @default(uuid())
  fullName              String             @map("full_name")
  email                 String             @unique
  passwordHash          String             @map("password_hash")
  phone                 String?
  whatsapp              String?
  country               String?
  avatarUrl             String?            @map("avatar_url") // profile photo URL (R2 or local)
  status                PortalMemberStatus @default(PENDING_VERIFICATION)
  referralCode          String             @unique @map("referral_code")
  referredById          String?            @map("referred_by_id")
  walletBalance         Float              @default(0) @map("wallet_balance")
  totalDeposited        Float              @default(0) @map("total_deposited")
  totalSpent            Float              @default(0) @map("total_spent")
  totalOrders           Int                @default(0) @map("total_orders")
  totalReferrals        Int                @default(0) @map("total_referrals")
  totalCommissionEarned Float              @default(0) @map("total_commission_earned")
  emailVerified         Boolean            @default(false) @map("email_verified")
  emailVerifyToken      String?            @map("email_verify_token")
  resetPasswordToken    String?            @map("reset_password_token")
  resetTokenExpiry      DateTime?          @map("reset_token_expiry")
  refreshToken          String?            @map("refresh_token")
  registrationDate      DateTime           @default(now()) @map("registration_date")
  lastLoginDate         DateTime?          @map("last_login_date")
  // Extended profile fields
  companyName           String?            @map("company_name")
  vatId                 String?            @map("vat_id")
  companyWebsite        String?            @map("company_website")
  industry              String?
  addressLine1          String?            @map("address_line_1")
  addressLine2          String?            @map("address_line_2")
  city                  String?
  state                 String?
  zip                   String?
  addressCountry        String?            @map("address_country")
  telegram              String?
  skype                 String?
  preferredContact      String?            @map("preferred_contact")
  preferences           Json?              @default("{}")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  // Relations
  referredBy        PortalMember?       @relation("Referrals", fields: [referredById], references: [id])
  referrals         PortalMember[]      @relation("Referrals")
  orders            PortalOrder[]
  walletTx          WalletTransaction[]
  commissionsEarned Commission[]        @relation("CommissionEarner")
  payoutRequests    PayoutRequest[]
  apkJobs           ApkJob[]
  sessions          PortalSession[]
  loginLogs         PortalLoginLog[]
  invoices          Invoice[]
  domains           Domain[]
  websites          Website[]

  @@map("portal_members")
}

model PortalOrder {
  id            String       @id @default(uuid())
  orderId       Int          @unique @default(autoincrement()) @map("order_id")
  memberId      String       @map("member_id")
  memberEmail   String       @map("member_email")
  service       String
  status        OrderStatus  @default(PENDING)
  paymentStatus String       @default("Pending") @map("payment_status")
  amountUsd     Float        @map("amount_usd")
  quantity      Int          @default(1)
  requirements  String?
  deliveryLink  String?      @map("delivery_link")
  orderDate     DateTime     @default(now()) @map("order_date")
  deadline      DateTime?
  deliveryDate  DateTime?    @map("delivery_date")
  revisionCount Int          @default(0) @map("revision_count")
  revisionNote  String?      @map("revision_note")
  rating        Float?
  reviewNote    String?      @map("review_note")
  notes         String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  member        PortalMember @relation(fields: [memberId], references: [id])
  commissions   Commission[]

  @@map("portal_orders")
}

model WalletTransaction {
  id              String       @id @default(uuid())
  memberId        String       @map("member_id")
  type            WalletTxType
  amountUsd       Float        @map("amount_usd")
  balanceAfterUsd Float        @map("balance_after_usd")
  paymentMethod   String?      @map("payment_method")
  status          String       @default("Pending")
  reference       String?
  transactionDate DateTime     @default(now()) @map("transaction_date")
  proofUrl        String?      @map("proof_url")
  approvedBy      String?      @map("approved_by")
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")
  member          PortalMember @relation(fields: [memberId], references: [id])

  @@map("wallet_transactions")
}

model Commission {
  id                  String           @id @default(uuid())
  earnerId            String           @map("earner_id")
  orderId             String           @map("order_id")
  referredMemberName  String?          @map("referred_member_name")
  orderAmountUsd      Float            @map("order_amount_usd")
  commissionRate      Float            @default(0.20) @map("commission_rate")
  commissionAmountUsd Float            @map("commission_amount_usd")
  status              CommissionStatus @default(PENDING_HOLD)
  holdReleaseDate     DateTime         @map("hold_release_date")
  payoutDate          DateTime?        @map("payout_date")
  payoutReference     String?          @map("payout_reference")
  fraudFlag           Boolean          @default(false) @map("fraud_flag")
  notes               String?
  createdAt           DateTime         @default(now()) @map("created_at")
  earner              PortalMember     @relation("CommissionEarner", fields: [earnerId], references: [id])
  order               PortalOrder      @relation(fields: [orderId], references: [id])

  @@map("commissions")
}

model PayoutRequest {
  id             String        @id @default(uuid())
  memberId       String        @map("member_id")
  memberEmail    String        @map("member_email")
  amountUsd      Float         @map("amount_usd")
  paymentMethod  PaymentMethod @map("payment_method")
  paymentDetails String?       @map("payment_details")
  status         PayoutStatus  @default(PENDING)
  requestedDate  DateTime      @default(now()) @map("requested_date")
  processedDate  DateTime?     @map("processed_date")
  processedBy    String?       @map("processed_by")
  transactionId  String?       @map("transaction_id")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  member         PortalMember  @relation(fields: [memberId], references: [id])

  @@map("payout_requests")
}

model ApkJob {
  id             String       @id @default(cuid())
  portalMemberId String       @map("portal_member_id")
  portalMember   PortalMember @relation(fields: [portalMemberId], references: [id], onDelete: Cascade)
  appName        String       @map("app_name")
  url            String
  plan           String       @default("free")
  status         String       @default("queued") // queued, processing, ready, failed, expired
  apkSizeMb      Float?       @map("apk_size_mb")
  downloadUrl    String?      @map("download_url")
  errorMessage   String?      @map("error_message")
  expiresAt      DateTime?    @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([portalMemberId])
  @@index([status])
  @@map("apk_jobs")
}

model PortalSession {
  id             String       @id @default(cuid())
  portalMemberId String       @map("portal_member_id")
  portalMember   PortalMember @relation(fields: [portalMemberId], references: [id], onDelete: Cascade)
  tokenHash      String       @map("token_hash")
  userAgent      String?      @map("user_agent")
  ipAddress      String?      @map("ip_address")
  country        String?
  city           String?
  deviceType     String?      @map("device_type") // desktop, mobile, tablet
  browserName    String?      @map("browser_name")
  osName         String?      @map("os_name")
  createdAt      DateTime     @default(now()) @map("created_at")
  lastActivityAt DateTime     @updatedAt @map("last_activity_at")
  expiresAt      DateTime     @map("expires_at")
  revokedAt      DateTime?    @map("revoked_at")

  @@index([portalMemberId])
  @@index([expiresAt])
  @@map("portal_sessions")
}

model PortalLoginLog {
  id             String       @id @default(cuid())
  portalMemberId String       @map("portal_member_id")
  portalMember   PortalMember @relation(fields: [portalMemberId], references: [id], onDelete: Cascade)
  email          String
  ipAddress      String?      @map("ip_address")
  userAgent      String?      @map("user_agent")
  country        String?
  city           String?
  deviceType     String?      @map("device_type")
  browserName    String?      @map("browser_name")
  osName         String?      @map("os_name")
  status         String       @default("success") // success, failed, suspicious
  failureReason  String?      @map("failure_reason")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([portalMemberId])
  @@index([createdAt(sort: Desc)])
  @@map("portal_login_logs")
}

model Notification {
  id            String   @id @default(uuid())
  recipientId   String   @map("recipient_id")
  recipientType String   @map("recipient_type") // "staff" | "portal"
  type          String
  title         String
  message       String
  read          Boolean  @default(false)
  link          String?
  metadata      String? // JSON string
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model Broadcast {
  id        String   @id @default(uuid())
  title     String
  message   String
  sentBy    String   @map("sent_by")
  audience  String // "staff" | "clients" | "all"
  channel   String // "in_app" | "email"
  isUrgent  Boolean  @default(false) @map("is_urgent")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("broadcasts")
}

model SupportTicket {
  id           String        @id @default(uuid())
  ticketNumber Int           @unique @default(autoincrement()) @map("ticket_number")
  memberId     String?       @map("member_id")
  memberEmail  String        @map("member_email")
  subject      String
  status       String        @default("Open")
  priority     String        @default("Medium")
  assignedTo   String?       @map("assigned_to")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  replies      TicketReply[]

  @@map("support_tickets")
}

model TicketReply {
  id         String        @id @default(uuid())
  ticketId   String        @map("ticket_id")
  authorId   String        @map("author_id")
  authorName String        @map("author_name")
  authorType String        @map("author_type") // "staff" | "client"
  content    String
  createdAt  DateTime      @default(now()) @map("created_at")
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_replies")
}

model Automation {
  id             String    @id @default(uuid())
  name           String    @unique
  description    String?
  status         String    @default("Active")
  trigger        String?
  frequency      String?
  nextRunDate    DateTime? @map("next_run_date")
  lastRunDate    DateTime? @map("last_run_date")
  lastRunStatus  String?   @map("last_run_status")
  runCount       Int       @default(0) @map("run_count")
  affectedModule String?   @map("affected_module")
  whatsappNotify Boolean   @default(false) @map("whatsapp_notify")
  errorLog       String?   @map("error_log")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("automations")
}

// ── Plugin Platform ──────────────────────────────────────────────────────────

model Plugin {
  id             String             @id @default(uuid())
  slug           String             @unique // used in WP update-checker URLs
  name           String
  description    String?
  status         String             @default("DRAFT") // DRAFT | PUBLISHED
  currentVersion String             @default("1.0.0") @map("current_version")
  createdById    String             @map("created_by_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  versions       PluginVersion[]
  activations    PluginActivation[]

  @@map("plugins")
}

model PluginVersion {
  id             String   @id @default(uuid())
  pluginId       String   @map("plugin_id")
  version        String // semver e.g. "1.0.0"
  changelog      String?
  phpFileContent String   @map("php_file_content") // full PHP source text
  isLatest       Boolean  @default(false) @map("is_latest")
  publishedAt    DateTime @default(now()) @map("published_at")
  publishedById  String   @map("published_by_id")
  plugin         Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([pluginId, version])
  @@map("plugin_versions")
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyHash     String    @unique @map("key_hash") // SHA-256 of raw key
  keyPrefix   String    @map("key_prefix") // first 8 chars for display
  scope       String    @default("plugin_download") // plugin_download | general
  isActive    Boolean   @default(true) @map("is_active")
  createdById String    @map("created_by_id")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("api_keys")
}

model PluginActivation {
  id              String    @id @default(uuid())
  pluginId        String    @map("plugin_id")
  activatedByType String    @map("activated_by_type") // "staff" | "portal"
  activatedById   String    @map("activated_by_id")
  activatedByName String?   @map("activated_by_name")
  siteUrl         String    @map("site_url")
  siteTitle       String?   @map("site_title")
  activatedAt     DateTime  @default(now()) @map("activated_at")
  lastPingAt      DateTime? @map("last_ping_at")
  isActive        Boolean   @default(true) @map("is_active")
  plugin          Plugin    @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([pluginId, siteUrl])
  @@map("plugin_activations")
}

// ── CCTV / Camera Monitoring ─────────────────────────────────────────────────
// TP-Link VIGI NVR OpenAPI (local HTTPS, default port 20443). One NVR per branch.

model VigiNvrIntegration {
  id                String    @id @default(uuid())
  branchId          String    @unique @map("branch_id")
  host              String
  port              Int       @default(20443)
  username          String    @default("admin")
  passwordEncrypted String    @map("password_encrypted")
  tlsAllowInsecure  Boolean   @default(false) @map("tls_allow_insecure")
  enabled           Boolean   @default(true)
  lastSyncAt        DateTime? @map("last_sync_at")
  lastError         String?   @map("last_error")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  cameras CameraDevice[]

  @@map("vigi_nvr_integrations")
}

model CameraDevice {
  id                String    @id @default(uuid())
  branchId          String    @map("branch_id")
  branchName        String?   @map("branch_name")
  label             String
  location          String?
  ipAddress         String?   @map("ip_address")
  streamUrl         String?   @map("stream_url")
  rtspUrl           String?   @map("rtsp_url")
  status            String    @default("online") // online | offline | recording
  resolution        String?   @default("1080p")
  fps               Int?      @default(25)
  angle             String?
  hasAudio          Boolean   @default(false) @map("has_audio")
  hasMotionDetect   Boolean   @default(true) @map("has_motion_detect")
  nvrDevice         String?   @map("nvr_device")
  // manual | vigi (VIGI OpenAPI sync)
  source            String    @default("manual") @map("source")
  vigiIntegrationId String?   @map("vigi_integration_id")
  vigiChannel       Int?      @map("vigi_channel")
  // Stable upsert key: integrationId:channel
  vigiSyncKey       String?   @unique @map("vigi_sync_key")
  lastPingAt        DateTime? @map("last_ping_at")
  lastMotionAt      DateTime? @map("last_motion_at")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  branch          Branch              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  vigiIntegration VigiNvrIntegration? @relation(fields: [vigiIntegrationId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([vigiIntegrationId])
  @@map("camera_devices")
}

// ── SEO / Web Tools audit log (management app) ───────────────────────────────

enum ToolRunType {
  SERP_TOP_100
  DOMAIN_METRICS
  BACKLINKS
  KEYWORDS
  FAVICON_ZIP
}

model ToolRun {
  id         String      @id @default(uuid())
  staffId    String      @map("staff_id")
  staff      StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  toolType   ToolRunType @map("tool_type")
  queryLabel String      @map("query_label") @db.VarChar(2000)
  meta       Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([staffId, createdAt(sort: Desc)])
  @@map("tool_runs")
}

// ── AI Assistant ─────────────────────────────────────────────────────────────

enum AiUseCase {
  BLOG
  SEO_BRIEF
  TASK
  REPORT
  CHAT
}

model AiConversation {
  id          String      @id @default(uuid())
  staffId     String      @map("staff_id")
  staff       StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  workspaceId String?     @map("workspace_id")
  useCase     AiUseCase   @map("use_case")
  title       String?
  provider    String
  model       String
  totalTokens Int         @default(0) @map("total_tokens")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  messages    AiMessage[]

  @@index([staffId, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(uuid())
  conversationId String         @map("conversation_id")
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  tokensUsed     Int            @default(0) @map("tokens_used")
  createdAt      DateTime       @default(now()) @map("created_at")

  @@index([conversationId])
  @@map("ai_messages")
}

model AiUsage {
  id        String    @id @default(uuid())
  staffId   String    @map("staff_id")
  provider  String
  model     String
  inputTk   Int       @map("input_tokens")
  outputTk  Int       @map("output_tokens")
  useCase   AiUseCase @map("use_case")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([staffId, createdAt(sort: Desc)])
  @@map("ai_usage")
}

// ── System Configuration & Audit Logs ────────────────────────────────────────

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  type        String   @default("string")
  group       String   @default("general")
  label       String?
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model SystemAuditLog {
  id           String   @id @default(uuid())
  actorId      String?  @map("actor_id")
  actorRole    String?  @map("actor_role")
  action       String
  resourceKind String   @map("resource_kind")
  resourceId   String   @map("resource_id")
  clientId     String?  @map("client_id")
  ip           String?
  userAgent    String?  @map("user_agent")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([resourceKind, resourceId])
  @@index([clientId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("system_audit_logs")
}

// ── CEO/MD Workspaces ────────────────────────────────────────────────────────

model Workspace {
  id             String           @id @default(uuid())
  ownerId        String           @map("owner_id")
  name           String
  description    String?
  contextNotes   String?          @map("context_notes")
  todos          String?
  conversationId String?          @map("conversation_id")
  githubRepoUrl  String?          @map("github_repo_url")
  githubBranch   String?          @map("github_branch")
  sshEnabled     Boolean          @default(false) @map("ssh_enabled")
  settings       String?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  files          WorkspaceFile[]
  skills         WorkspaceSkill[]

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceSkill {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  content     String
  category    String    @default("custom")
  enabled     Boolean   @default(true)
  priority    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([workspaceId])
  @@map("workspace_skills")
}

model GitHubConnection {
  id          String   @id @default(uuid())
  staffId     String   @unique @map("staff_id")
  accessToken String   @map("access_token")
  username    String
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("github_connections")
}

model IntegrationConnection {
  id           String    @id @default(uuid())
  staffId      String    @map("staff_id")
  provider     String
  accessToken  String    @map("access_token")
  refreshToken String?   @map("refresh_token")
  displayName  String    @map("display_name")
  avatarUrl    String?   @map("avatar_url")
  metadata     String?
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([staffId, provider])
  @@index([staffId])
  @@map("integration_connections")
}

model WorkspaceFile {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  path        String
  name        String
  isDirectory Boolean   @default(false) @map("is_directory")
  mimeType    String?   @map("mime_type")
  size        Int       @default(0)
  content     String?
  storageKey  String?   @map("storage_key")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([workspaceId, path])
  @@index([workspaceId])
  @@map("workspace_files")
}

// ── EMAIL INBOX ───────────────────────────────────────────────────────────────

model EmailAccount {
  id            String      @id @default(uuid())
  staffMemberId String      @map("staff_member_id")
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  address       String      @unique // e.g. john@pouchcare.com
  displayName   String      @map("display_name") // "John Doe"
  signature     String? // HTML signature
  isPrimary     Boolean     @default(false) @map("is_primary")
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  sentMessages     EmailMessage[]   @relation("SentMessages")
  receivedMessages EmailRecipient[]

  @@index([staffMemberId])
  @@map("email_accounts")
}

model EmailMessage {
  id          String       @id @default(uuid())
  accountId   String       @map("account_id")
  account     EmailAccount @relation("SentMessages", fields: [accountId], references: [id], onDelete: Cascade)
  subject     String
  body        String // HTML content
  bodyText    String?      @map("body_text") // plain-text fallback
  threadId    String?      @map("thread_id") // group replies
  inReplyToId String?      @map("in_reply_to_id") // parent message
  resendId    String?      @map("resend_id") // Resend API message ID
  status      String       @default("sent") // draft | queued | sent | failed
  isRead      Boolean      @default(true) @map("is_read")
  isStarred   Boolean      @default(false) @map("is_starred")
  isDraft     Boolean      @default(false) @map("is_draft")
  folder      String       @default("sent") // inbox | sent | drafts | trash | archive
  sentAt      DateTime?    @map("sent_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  recipients  EmailRecipient[]
  attachments EmailAttachment[]

  @@index([accountId])
  @@index([threadId])
  @@index([folder])
  @@index([createdAt])
  @@map("email_messages")
}

model EmailRecipient {
  id        String        @id @default(uuid())
  messageId String        @map("message_id")
  message   EmailMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  accountId String?       @map("account_id") // if recipient is an internal account
  account   EmailAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  address   String // email address
  name      String? // display name
  type      String        @default("to") // to | cc | bcc
  isRead    Boolean       @default(false) @map("is_read")
  isStarred Boolean       @default(false) @map("is_starred")
  folder    String        @default("inbox") // inbox | trash | archive | spam

  @@index([messageId])
  @@index([accountId])
  @@index([address])
  @@map("email_recipients")
}

model EmailAttachment {
  id         String       @id @default(uuid())
  messageId  String       @map("message_id")
  message    EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName   String       @map("file_name")
  fileSize   Int          @map("file_size")
  mimeType   String       @map("mime_type")
  storageKey String       @map("storage_key") // R2 object key
  url        String? // signed URL (generated on demand)

  @@index([messageId])
  @@map("email_attachments")
}
