# ─────────────────────────────────────────────────────────────
# PouchCare OS — API Environment Variables
# Copy to apps/api/.env and fill in values
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Direct MySQL 8 URL (mysql://). Use a utf8mb4 / *_ci collation database (case-insensitive search relies on it).
# If login/queries fail with "URL must start with prisma://", regenerate the client: from apps/api run `npx prisma generate`.
DATABASE_URL=mysql://pouchcare:pouchcare@localhost:3306/pouchcare
REDIS_URL=redis://127.0.0.1:6379

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change_me_minimum_32_characters_long_secret_key_here
JWT_REFRESH_SECRET=change_me_different_minimum_32_chars_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── VIGI NVR (optional) ───────────────────────────────────────
# Encrypts stored NVR passwords. 64 hex chars = 32-byte AES key; if unset, a key is derived from JWT_SECRET.
# VIGI_CREDENTIALS_KEY=
# HTTPS to NVR OpenAPI / snapshot — ms (5000–180000). Default 60000. Raise only for slow VPN; does not fix wrong network.
# VIGI_HTTPS_TIMEOUT_MS=60000

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=hello@pouchcare.com

# ── CORS ──────────────────────────────────────────────────────
# Production domains (no .bd — correct domains)
# In NODE_ENV=development, http://localhost:* and http://127.0.0.1:* are also allowed (any port) for Vite.
ALLOWED_ORIGINS=https://pouchcare.com,https://www.pouchcare.com,https://m.pouchcare.com,https://office.pouchcare.com,https://api.pouchcare.com,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000,http://localhost:3001

# ── App ───────────────────────────────────────────────────────
PORT=7000
NODE_ENV=production
FRONTEND_URL=https://pouchcare.com
# Client portal base URL (email verification & password reset links for portal members)
# Client UI base (verify email, reset links) — production: https://pouchcare.com (paths /my-accounts/…)
PORTAL_URL=https://pouchcare.com

# ── File Storage (Cloudflare R2 / S3-compatible) ───────────────
# Create a bucket in Cloudflare Dashboard → R2 → Create bucket.
# Create "S3 API" credentials: R2 → Manage R2 API Tokens → Create API token
#   (Access Key ID + Secret Access Key). Use those below.
# The long "Account API Token" (cfat_...) is for Cloudflare's REST API, not @aws-sdk/client-s3.
# EU jurisdiction endpoint example: https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=pouchcare-uploads
S3_REGION=auto
S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# Either pair works (R2 dashboard labels match *_ID / *_ACCESS_KEY):
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# Public URL of this API (local disk uploads only; R2 URLs use the endpoint above).
# Local dev: http://localhost:7000. Docker hosting sets API_URL=https://api.pouchcare.com in docker-compose.hosting.yml.
API_URL=http://localhost:7000
# Set true only for local dev without R2 (never in production). Production always uses R2.
STORAGE_LOCAL_FALLBACK=false
# After filling S3_* above: npm run test:r2

# ── Business Rules ────────────────────────────────────────────
COMMISSION_RATE=0.20

# ── Domain Registrar (Name.com) ───────────────────────────────
# API credentials from https://www.name.com/account/settings/api
NAMECOM_USERNAME=abdullahbabuofficial@gmail.com
NAMECOM_TOKEN=your_namecom_api_token
# Production: https://api.name.com  |  Dev/Test: https://api.dev.name.com
NAMECOM_API_URL=https://api.name.com
COMMISSION_HOLD_DAYS=14
MIN_PAYOUT_USD=50
DEFAULT_USD_TO_BDT=124

# ── SEO Tools (management /v1/tools) ─────────────────────────
# Optional — routes return 503 until configured. See apps/api/src/lib/tools/config.ts
# SerpAPI: https://serpapi.com — Google organic SERP
SERPAPI_API_KEY=
# Open PageRank (free): https://www.domcop.com/openpagerank/
OPENPAGERANK_API_KEY=
# DataForSEO: https://dataforseo.com — backlinks + keyword ideas (Basic auth).
# LOGIN = your DataForSEO account email; PASSWORD = API password from the dashboard (plain text only).
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── AI Providers (optional — AI features degrade gracefully) ──
# At least one key is required for /v1/ai/* routes.
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Google AI (Gemini): https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=
# Groq: https://console.groq.com/keys
GROQ_API_KEY=
# OpenRouter (200+ models): https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# Default provider when client doesn't specify (openai | anthropic | google | groq | openrouter)
AI_DEFAULT_PROVIDER=openai
# Default model name for the chosen provider
AI_DEFAULT_MODEL=gpt-4o
# Monthly token budget per staff member (0 = unlimited)
AI_MONTHLY_TOKEN_LIMIT=5000000

# ── Security ──────────────────────────────────────────────────
IP_WHITELIST_ENABLED=false
IP_WHITELIST=127.0.0.1,::1

# ── Cloudflare Tunnel (host apps from this machine) ───────────
# Used by: npm run tunnel:setup  (scripts/cf-tunnel-setup.mjs) then  npm run tunnel:up
# tunnel:setup (create tunnel + set ingress) needs a FULL API token with
#   Account > Cloudflare Tunnel > Edit  AND  Zone > DNS > Edit.
# A tunnel-scoped "cfut_" token can manage DNS but NOT tunnel config — in that
# case configure Public Hostnames in the dashboard and just use tunnel:up.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Provide the zone id directly, or leave blank to resolve from CLOUDFLARE_ZONE_NAME.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ZONE_NAME=pouchcare.com.bd
# Optional overrides:
# CF_TUNNEL_NAME=pouchcare
# CF_HOSTS=api.pouchcare.com.bd=7000,m.pouchcare.com.bd=3000,office.pouchcare.com.bd=5175,www.pouchcare.com.bd=3001,pouchcare.com.bd=3001
# Written automatically by tunnel:setup (or from the dashboard tunnel wizard):
# TUNNEL_TOKEN=
