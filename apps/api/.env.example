# ─────────────────────────────────────────────────────────────
# PouchCare OS — API Environment Variables
# Copy to apps/api/.env and fill in values
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Direct PostgreSQL URL (postgresql:// or postgres://). Do not use prisma:// here unless you use Prisma Accelerate with a matching client.
# If login/queries fail with "URL must start with prisma://", regenerate the client (no Data Proxy): from apps/api run `npx prisma generate` and never use `prisma generate --no-engine` for this API.
DATABASE_URL=postgresql://pouchcare:pouchcare@localhost:5432/pouchcare
REDIS_URL=redis://127.0.0.1:6379

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change_me_minimum_32_characters_long_secret_key_here
JWT_REFRESH_SECRET=change_me_different_minimum_32_chars_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── VIGI NVR (optional) ───────────────────────────────────────
# Encrypts stored NVR passwords. 64 hex chars = 32-byte AES key; if unset, a key is derived from JWT_SECRET.
# VIGI_CREDENTIALS_KEY=

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=hello@pouchcare.com

# ── CORS ──────────────────────────────────────────────────────
# Production domains (no .bd — correct domains)
ALLOWED_ORIGINS=https://pouchcare.com,https://www.pouchcare.com,https://m.pouchcare.com,https://office.pouchcare.com,https://api.pouchcare.com,http://localhost:5173,http://localhost:5174,http://localhost:5175

# ── App ───────────────────────────────────────────────────────
PORT=7000
NODE_ENV=production
FRONTEND_URL=https://pouchcare.com
# Client portal base URL (email verification & password reset links for portal members)
# Client UI base (verify email, reset links) — production: https://pouchcare.com (paths /my-accounts/…)
PORTAL_URL=https://pouchcare.com

# ── File Storage (Cloudflare R2 / S3-compatible) ───────────────
# Create a bucket in Cloudflare Dashboard → R2 → Create bucket.
# Create "S3 API" credentials: R2 → Manage R2 API Tokens → Create API token
#   (Access Key ID + Secret Access Key). Use those below.
# The long "Account API Token" (cfat_...) is for Cloudflare's REST API, not @aws-sdk/client-s3.
# EU jurisdiction endpoint example: https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=pouchcare-uploads
S3_REGION=auto
S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# Either pair works (R2 dashboard labels match *_ID / *_ACCESS_KEY):
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# Public URL of this API (local disk uploads only; R2 URLs use the endpoint above)
API_URL=http://localhost:7000
# Set true only for local dev without R2 (never in production). Production always uses R2.
STORAGE_LOCAL_FALLBACK=false
# After filling S3_* above: npm run test:r2

# ── Business Rules ────────────────────────────────────────────
COMMISSION_RATE=0.20

# ── Domain Registrar (Name.com) ───────────────────────────────
# API credentials from https://www.name.com/account/settings/api
NAMECOM_USERNAME=abdullahbabuofficial@gmail.com
NAMECOM_TOKEN=your_namecom_api_token
# Production: https://api.name.com  |  Dev/Test: https://api.dev.name.com
NAMECOM_API_URL=https://api.name.com
COMMISSION_HOLD_DAYS=14
MIN_PAYOUT_USD=50
DEFAULT_USD_TO_BDT=124

# ── SEO Tools (management /v1/tools) ─────────────────────────
# Optional — routes return 503 until configured. See apps/api/src/lib/tools/config.ts
# SerpAPI: https://serpapi.com — Google organic SERP
SERPAPI_API_KEY=
# Open PageRank (free): https://www.domcop.com/openpagerank/
OPENPAGERANK_API_KEY=
# DataForSEO: https://dataforseo.com — backlinks + keyword ideas (Basic auth)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Security ──────────────────────────────────────────────────
IP_WHITELIST_ENABLED=false
IP_WHITELIST=127.0.0.1,::1
