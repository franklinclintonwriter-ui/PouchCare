# ─────────────────────────────────────────────────────────────
# PouchCare API — DEVELOPMENT / STAGING (docker-compose.hosting.dev.yml)
# Copy to apps/api/.env.dev — never use production JWT_* here.
# Compose overrides DATABASE_URL, REDIS_URL, and sets API_URL → https://api-dev.pouchcare.com
# ─────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://pouchcare:pouchcare_dev@localhost:5433/pouchcare_dev
REDIS_URL=redis://127.0.0.1:6380

# Must differ from production apps/api/.env (invalidates prod tokens if reused carelessly).
JWT_SECRET=change_me_dev_only_minimum_32_characters_secret_key_here
JWT_REFRESH_SECRET=change_me_dev_only_different_minimum_32_chars_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=hello@pouchcare.com

# Include dev API origin, local Vite, and Cloudflare Pages preview/production URLs you use for dev.
# Include VPS Vite dev (docker-compose.frontend-dev.yml) + Cloudflare Pages + local.
ALLOWED_ORIGINS=https://api-dev.pouchcare.com,https://dev-m.pouchcare.com,https://dev-pouchcare.com,https://dev.pouchcare.com,https://pouchcare.com,https://www.pouchcare.com,https://m.pouchcare.com,https://office.pouchcare.com,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000,http://localhost:3001

PORT=7000
NODE_ENV=production
FRONTEND_URL=https://pouchcare.com
PORTAL_URL=https://pouchcare.com

# R2: use a separate dev bucket or prefix if you want strict isolation; optional for pure API dev.
S3_BUCKET=pouchcare-uploads-dev
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
API_URL=https://api-dev.pouchcare.com
STORAGE_LOCAL_FALLBACK=false

COMMISSION_RATE=0.20
NAMECOM_USERNAME=
NAMECOM_TOKEN=
NAMECOM_API_URL=https://api.name.com
COMMISSION_HOLD_DAYS=14
MIN_PAYOUT_USD=50
DEFAULT_USD_TO_BDT=124

IP_WHITELIST_ENABLED=false
IP_WHITELIST=127.0.0.1,::1
