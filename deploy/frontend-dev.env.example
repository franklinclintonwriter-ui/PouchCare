# Optional: copy to deploy/frontend-dev.env and reference with:
#   docker compose --env-file deploy/frontend-dev.env -f docker-compose.frontend-dev.yml up -d
#
# Or set these in the shell / root .env for docker compose interpolation.

# Dev API used by Vite in the frontend-dev container (browser calls this origin).
VITE_DEV_API_URL=https://api-dev.pouchcare.com
VITE_DEV_WS_URL=wss://api-dev.pouchcare.com/v1/realtime

# If the repo on the VPS is not the compose working directory, set absolute path:
# FRONTEND_DEV_ROOT=/opt/pouchcare
